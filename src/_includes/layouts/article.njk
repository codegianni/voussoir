<!DOCTYPE html>
<html lang="en-GB" data-theme="">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta name="robots" content="noindex, nofollow">
  <title>{{ title }} — Voussoir</title>
  <meta name="description" content="{{ deck }}">
  <meta property="og:title" content="{{ title }} — Voussoir">
  <meta property="og:description" content="{{ deck }}">
  <meta property="og:type" content="article">
  <meta property="og:url" content="https://voussoir.eu{{ page.url }}">
  <meta name="twitter:card" content="summary_large_image">
  <meta name="twitter:title" content="{{ title }} — Voussoir">
  <link rel="icon" type="image/svg+xml" href="/img/favicon.svg?v=3">
  <link rel="icon" type="image/png" sizes="32x32" href="/img/favicon.png?v=3">
  <link rel="apple-touch-icon" sizes="180x180" href="/img/apple-touch-icon.png?v=3">
  <link href="https://fonts.googleapis.com/css2?family=DM+Serif+Display:ital@0;1&family=Playfair+Display:ital,wght@0,400;0,600;0,700;1,400&family=Inter:wght@300;400;500;600&display=swap" rel="stylesheet">

  <style>
    * {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
    }

    :root {
      --ink: #111111;
      --ink-soft: #484848;
      --ink-faint: #888888;
      --paper: #ffffff;
      --cream: #f2f2f2;
      --rule: #d8d8d8;
      --surface-dark: #111111;
      --serif: 'Playfair Display', Georgia, serif;
      --display: 'DM Serif Display', Georgia, serif;
      --sans: 'Inter', system-ui, sans-serif;
    }

    @media (prefers-color-scheme: dark) {
      :root:not([data-theme="light"]) {
        --ink: #e8e8e8;
        --ink-soft: #969696;
        --ink-faint: #585858;
        --paper: #111111;
        --cream: #1a1a1a;
        --rule: #2a2a2a;
        --surface-dark: #080808;
      }
    }

    [data-theme="light"] {
      --ink: #111111;
      --ink-soft: #484848;
      --ink-faint: #888888;
      --paper: #ffffff;
      --cream: #f2f2f2;
      --rule: #d8d8d8;
      --surface-dark: #111111;
    }

    [data-theme="dark"] {
      --ink: #e8e8e8;
      --ink-soft: #969696;
      --ink-faint: #585858;
      --paper: #111111;
      --cream: #1a1a1a;
      --rule: #2a2a2a;
      --surface-dark: #080808;
    }

    body {
      background-color: var(--paper);
      color: var(--ink);
      font-family: var(--sans);
      line-height: 1.6;
      transition: background-color 0.2s, color 0.2s;
      -webkit-font-smoothing: antialiased;
      -moz-osx-font-smoothing: grayscale;
    }


    /* ARTICLE HEADER */
    .article-header {
      max-width: 760px;
      margin: 0 auto;
      padding: 64px 32px 48px;
      text-align: center;
    }

    .breadcrumb {
      font-family: var(--sans);
      font-size: 11px;
      font-weight: 500;
      letter-spacing: 0.05em;
      text-transform: uppercase;
      color: var(--ink-faint);
      margin-bottom: 24px;
    }

    .article-meta-line {
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 12px;
      margin-bottom: 20px;
      font-family: var(--sans);
      font-size: 13px;
      color: var(--ink-faint);
    }

    .category-tag {
      border: 1px solid var(--rule);
      padding: 6px 12px;
      font-family: var(--sans);
      font-size: 12px;
      font-weight: 500;
      color: var(--ink);
      text-decoration: none;
      display: inline-block;
    }

    .article-title {
      font-family: var(--display);
      font-size: 52px;
      font-weight: 400;
      line-height: 1.1;
      color: var(--ink);
      margin-bottom: 20px;
    }

    .article-title em {
      font-style: italic;
    }

    .article-deck {
      font-family: var(--serif);
      font-size: 22px;
      font-style: italic;
      line-height: 1.6;
      color: var(--ink-soft);
      margin-bottom: 32px;
    }

    .divider {
      height: 1px;
      background-color: var(--rule);
      margin: 32px 0;
    }

    .author-row {
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 12px;
      flex-wrap: wrap;
      font-family: var(--sans);
      font-size: 13px;
      color: var(--ink-soft);
    }

    .author-avatar {
      width: 32px;
      height: 32px;
      border-radius: 50%;
      background-color: var(--rule);
      display: flex;
      align-items: center;
      justify-content: center;
      font-weight: 600;
      color: var(--ink);
      font-size: 12px;
    }

    .separator {
      color: var(--ink-faint);
    }

    /* HERO IMAGE */
    .hero-image {
      width: 100%;
      height: 520px;
      background: linear-gradient(160deg, #2a2a2a 0%, #111111 60%, #1e1e1e 100%);
      margin-bottom: 24px;
    }

    .image-caption {
      max-width: 760px;
      margin: 0 auto 48px;
      padding: 0 32px;
      font-family: var(--sans);
      font-size: 12px;
      color: var(--ink-faint);
      text-align: center;
    }

    /* ARTICLE BODY */
    .article-body {
      max-width: 680px;
      margin: 0 auto;
      padding: 0 32px;
    }

    .article-body p {
      font-family: var(--sans);
      font-size: 18px;
      line-height: 1.85;
      color: var(--ink-soft);
      margin-bottom: 24px;
      overflow-wrap: break-word;
      word-break: break-word;
    }

    .article-body h2 {
      font-family: var(--serif);
      font-size: 26px;
      font-weight: 400;
      color: var(--ink);
      margin: 48px 0 16px;
    }

    .pullquote {
      font-family: var(--display);
      font-size: 28px;
      font-style: italic;
      line-height: 1.6;
      color: var(--ink);
      border-left: 3px solid var(--ink);
      padding-left: 28px;
      margin: 48px 0;
    }

    /* ARTICLE FOOTER */
    .article-footer {
      max-width: 680px;
      margin: 64px auto 0;
      padding: 0 32px;
    }

    .article-footer .divider {
      margin: 32px 0;
    }

    .tags-row {
      display: flex;
      flex-wrap: wrap;
      gap: 12px;
      margin-bottom: 32px;
    }

    .tag {
      border: 1px solid var(--rule);
      padding: 8px 14px;
      font-family: var(--sans);
      font-size: 12px;
      font-weight: 500;
      color: var(--ink);
      text-decoration: none;
      display: inline-block;
      transition: all 0.2s;
    }

    .tag:hover {
      border-color: var(--ink);
    }

    .share-row {
      margin-bottom: 48px;
      display: flex;
      align-items: center;
      gap: 12px;
      font-family: var(--sans);
      font-size: 13px;
      color: var(--ink-soft);
      flex-wrap: wrap;
    }

    .share-row strong {
      color: var(--ink);
    }

    .share-row a {
      color: var(--ink);
      text-decoration: none;
      font-weight: 500;
      transition: color 0.2s;
    }

    .share-row a:hover {
      color: var(--ink-soft);
    }

    .share-divider {
      color: var(--ink-faint);
    }

    .about-author {
      background-color: var(--cream);
      padding: 28px;
      margin-bottom: 64px;
      display: flex;
      gap: 20px;
      align-items: flex-start;
    }

    .author-info {
      flex: 1;
    }

    .author-name {
      font-family: var(--sans);
      font-size: 15px;
      font-weight: 600;
      color: var(--ink);
      margin-bottom: 8px;
    }

    .author-bio {
      font-family: var(--sans);
      font-size: 13px;
      line-height: 1.6;
      color: var(--ink-soft);
      margin-bottom: 12px;
    }

    .author-link {
      font-family: var(--sans);
      font-size: 13px;
      font-weight: 500;
      color: var(--ink);
      text-decoration: none;
      transition: color 0.2s;
    }

    .author-link:hover {
      color: var(--ink-soft);
    }

    /* RELATED ARTICLES */
    .related-section {
      background-color: var(--cream);
      padding: 64px 32px;
      margin-top: 64px;
    }

    .related-container {
      max-width: 1400px;
      margin: 0 auto;
    }

    .section-header {
      font-family: var(--serif);
      font-size: 32px;
      font-weight: 400;
      color: var(--ink);
      margin-bottom: 48px;
      text-align: center;
    }

    .articles-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 40px;
    }

    .article-card {
      text-decoration: none;
      color: inherit;
      transition: transform 0.2s;
    }

    .article-card:hover {
      transform: translateY(-4px);
    }

    .card-image {
      width: 100%;
      height: 240px;
      background: linear-gradient(135deg, #111111 0%, #2a2a2a 100%);
      margin-bottom: 16px;
    }

    .card-meta {
      font-family: var(--sans);
      font-size: 12px;
      font-weight: 500;
      color: var(--ink-faint);
      margin-bottom: 8px;
      display: flex;
      align-items: center;
      gap: 8px;
    }

    .card-tag {
      border: 1px solid var(--rule);
      padding: 4px 8px;
      display: inline-block;
      font-size: 11px;
    }

    .card-title {
      font-family: var(--serif);
      font-size: 18px;
      font-weight: 600;
      line-height: 1.4;
      color: var(--ink);
      margin-bottom: 8px;
    }

    .card-excerpt {
      font-family: var(--sans);
      font-size: 14px;
      line-height: 1.6;
      color: var(--ink-soft);
    }

    /* NEWSLETTER */
    .newsletter-section {
      background-color: var(--cream);
      padding: 64px 32px;
      text-align: center;
    }

    .newsletter-container {
      max-width: 500px;
      margin: 0 auto;
    }

    .newsletter-heading {
      font-family: var(--serif);
      font-size: 18px;
      font-weight: 400;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      color: var(--ink);
      margin-bottom: 24px;
    }

    .newsletter-form {
      display: flex;
      gap: 8px;
    }

    .newsletter-input {
      flex: 1;
      border: 1px solid var(--rule);
      padding: 12px 16px;
      font-family: var(--sans);
      font-size: 14px;
      background-color: var(--paper);
      color: var(--ink);
      transition: border-color 0.2s;
    }

    .newsletter-input:focus {
      outline: none;
      border-color: var(--ink);
    }

    .newsletter-input::placeholder {
      color: var(--ink-faint);
    }

    .newsletter-button {
      border: 1px solid var(--ink);
      padding: 12px 24px;
      font-family: var(--sans);
      font-size: 13px;
      font-weight: 600;
      background-color: var(--ink);
      color: var(--paper);
      cursor: pointer;
      transition: all 0.2s;
    }

    .newsletter-button:hover {
      background-color: var(--ink-soft);
      border-color: var(--ink-soft);
    }

    /* UNIFIED COMPACT FOOTER */
    .site-footer {
      background: var(--paper);
      border-top: 1px solid var(--rule);
      padding: 40px 0 36px;
    }
    .footer-inner {
      max-width: 1200px;
      margin: 0 auto;
      padding: 0 32px;
      display: grid;
      grid-template-columns: 2fr 1fr 1fr 1fr;
      gap: 32px;
    }
    .footer-brand-name {
      font-family: var(--serif);
      font-size: 36px;
      font-weight: 700;
      letter-spacing: -0.5px;
      color: var(--ink);
      text-decoration: none;
      display: block;
      margin-bottom: 10px;
    }
    .footer-brand-desc {
      font-size: 12px;
      color: var(--ink-faint);
      line-height: 1.5;
      margin-bottom: 16px;
    }
    .footer-copy {
      font-size: 11px;
      color: var(--ink-faint);
    }
    .footer-copy a { color: inherit; }
    .footer-col-head {
      font-size: 10px;
      font-weight: 600;
      text-transform: uppercase;
      letter-spacing: 0.08em;
      color: var(--ink-faint);
      margin-bottom: 12px;
    }
    .footer-col-list { list-style: none; }
    .footer-col-list li { margin-bottom: 8px; }
    .footer-col-list a {
      font-size: 13px;
      color: var(--ink-soft);
      text-decoration: none;
      transition: color 0.15s;
    }
    .footer-col-list a:hover { color: var(--ink); }

    /* RESPONSIVE */
    @media (max-width: 768px) {
      .article-header {
        padding: 48px 16px 36px;
      }

      .article-title {
        font-size: 36px;
      }

      .article-deck {
        font-size: 18px;
      }

      .article-body {
        padding: 0 16px;
      }

      .article-body p {
        font-size: 16px;
      }

      .hero-image {
        height: 320px;
      }

      .articles-grid {
        grid-template-columns: 1fr;
      }

      .about-author {
        flex-direction: column;
        align-items: center;
        text-align: center;
      }

      .footer-inner {
        grid-template-columns: 1fr 1fr;
        gap: 28px;
      }
    }

    @media (max-width: 480px) {
      .article-title { font-size: 28px; }
      .article-deck { font-size: 16px; }
      .article-meta { flex-wrap: wrap; gap: 6px; }
      .tags-row { flex-wrap: wrap; }
      .footer-inner { grid-template-columns: 1fr; padding: 0 16px; }
      .articles-grid { grid-template-columns: 1fr; }
      .overlay-inner { padding: 0 16px; gap: 32px; }
      .overlay-topics { grid-template-columns: 1fr; }
      .overlay-topics li:nth-child(odd) a { padding-right: 0; }
      .overlay-topics li:nth-child(even) a { padding-left: 0; }
      .overlay-search-input { min-width: 0; }
    }

    /* ─── MOBILE THEME TOGGLE ───────────────────────────── */
    @media (max-width: 767px) {
      #themeToggle { display: none; }
    }
    .overlay-theme-row { display: none; }
    @media (max-width: 767px) {
      .overlay-theme-row { display: block; }
    }
    .overlay-theme-btn {
      background: none;
      border: none;
      border-top: 1px solid var(--rule);
      cursor: pointer;
      color: var(--ink);
      display: flex;
      align-items: center;
      gap: 12px;
      padding: 14px 0;
      width: 100%;
      font-family: var(--sans);
      font-size: 13px;
      font-weight: 500;
      letter-spacing: 0.02em;
      transition: opacity 0.2s;
      text-align: left;
    }
    .overlay-theme-btn:hover { opacity: 0.45; }
    .overlay-theme-btn svg {
      width: 18px; height: 18px;
      stroke: currentColor; fill: none;
      stroke-width: 1.5; stroke-linecap: round; stroke-linejoin: round;
      flex-shrink: 0;
    }

    /* SITE HEADER & NAV */
    .site-header {
      position: sticky; top: 0; z-index: 200;
      background: var(--paper); border-bottom: 1px solid var(--rule);
      transition: background 0.3s, border-color 0.3s;
    }
    .nav-inner {
      display: grid; grid-template-columns: 1fr auto 1fr;
      align-items: center; height: 64px; padding: 0 24px;
    }
    .nav-left { display: flex; align-items: center; gap: 20px; }
    .site-logo {
      font-family: var(--serif); font-size: 26px; font-weight: 700;
      letter-spacing: -0.5px; color: var(--ink); line-height: 1;
      grid-column: 2; justify-self: center; white-space: nowrap; text-decoration: none;
    }
    .nav-right { display: flex; align-items: center; gap: 16px; justify-content: flex-end; }
    .nav-icon-btn {
      background: none; border: none; cursor: pointer; color: var(--ink);
      display: flex; align-items: center; justify-content: center;
      padding: 4px; transition: opacity 0.2s;
    }
    .nav-icon-btn:hover { opacity: 0.5; }
    .nav-icon-btn svg { width: 20px; height: 20px; stroke: currentColor; fill: none; stroke-width: 1.5; stroke-linecap: round; stroke-linejoin: round; }
    .icon-close { display: none; } .icon-burger { display: block; }
    .menu-open .icon-close { display: block; } .menu-open .icon-burger { display: none; }
    .icon-sun { display: none; } .icon-moon { display: block; }
    [data-theme="dark"] .icon-sun { display: block; } [data-theme="dark"] .icon-moon { display: none; }
    @media (prefers-color-scheme: dark) {
      html:not([data-theme="light"]) .icon-sun { display: block; }
      html:not([data-theme="light"]) .icon-moon { display: none; }
    }
    .nav-cta {
      font-family: var(--sans); font-size: 11px; font-weight: 500;
      letter-spacing: 0.1em; text-transform: uppercase; color: var(--ink);
      border: 1px solid var(--ink); padding: 7px 16px; border-radius: 999px;
      white-space: nowrap; transition: background 0.2s, color 0.2s; text-decoration: none;
    }
    .nav-cta:hover { background: var(--ink); color: var(--paper); }
    .nav-overlay {
      position: fixed; top: 64px; left: 0; right: 0; background: var(--paper);
      border-top: 1px solid var(--rule); border-bottom: 1px solid var(--rule);
      z-index: 199; padding: 52px 0 60px;
      opacity: 0; pointer-events: none; transform: translateY(-8px);
      transition: opacity 0.25s ease, transform 0.25s ease;
    }
    .nav-overlay.is-open { opacity: 1; pointer-events: all; transform: translateY(0); }
    .overlay-inner {
      max-width: 1200px; margin: 0 auto; padding: 0 32px;
      display: grid; grid-template-columns: 3fr 2fr; gap: 80px; align-items: start;
    }
    .overlay-topics-label, .overlay-search-label {
      font-family: var(--sans); font-size: 10px; font-weight: 700;
      letter-spacing: 0.2em; text-transform: uppercase;
      color: var(--ink-faint); margin-bottom: 28px;
    }
    .overlay-topics { list-style: none; display: grid; grid-template-columns: 1fr 1fr; }
    .overlay-topics li a {
      font-family: var(--serif); font-size: 26px; font-weight: 400; color: var(--ink);
      line-height: 1.25; display: block; padding: 10px 0;
      transition: opacity 0.2s; text-decoration: none;
    }
    .overlay-topics li a:hover { opacity: 0.4; }
    .overlay-topics li:nth-child(odd) a { padding-right: 32px; }
    .overlay-topics li:nth-child(even) a { padding-left: 32px; }
    .overlay-topics li:last-child:nth-child(odd) { grid-column: 1 / -1; }
    .overlay-topics li:last-child:nth-child(odd) a { padding-right: 0; border-left: none; }
    .overlay-search-form {
      display: flex; align-items: center;
      border-bottom: 1px solid var(--ink); padding-bottom: 2px; gap: 8px;
    }
    .overlay-search-input {
      font-family: var(--serif); font-size: 20px; background: none;
      border: none; outline: none; color: var(--ink); flex: 1; padding: 10px 0;
      font-style: italic;
    }
    .overlay-search-input::placeholder { color: var(--ink-faint); font-style: italic; }
    .overlay-search-btn {
      background: none; border: none; cursor: pointer;
      font-family: var(--sans); font-size: 12px; font-weight: 600;
      letter-spacing: 0.12em; text-transform: uppercase;
      color: var(--ink-faint); padding: 10px 0; transition: color 0.2s; white-space: nowrap;
    }
    .overlay-search-btn:hover { color: var(--ink); }
  </style>
</head>
<body>

  <!-- HEADER -->
  <header class="site-header" id="siteHeader">
    <nav class="nav-inner">
      <div class="nav-left">
        <button class="nav-icon-btn" id="menuToggle" aria-label="Open menu" aria-expanded="false">
          <svg class="icon-burger" viewBox="0 0 24 24"><line x1="3" y1="6" x2="21" y2="6"/><line x1="3" y1="12" x2="21" y2="12"/><line x1="3" y1="18" x2="21" y2="18"/></svg>
          <svg class="icon-close" viewBox="0 0 24 24"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
        </button>
        <button class="nav-icon-btn" id="searchToggle" aria-label="Search">
          <svg viewBox="0 0 24 24"><circle cx="11" cy="11" r="7"/><line x1="16.5" y1="16.5" x2="22" y2="22"/></svg>
        </button>
      </div>
      <a href="/" class="site-logo">Voussoir.</a>
      <div class="nav-right">
        <button class="nav-icon-btn" id="themeToggle" aria-label="Toggle dark mode">
          <svg class="icon-moon" viewBox="0 0 24 24"><path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/></svg>
          <svg class="icon-sun" viewBox="0 0 24 24"><circle cx="12" cy="12" r="5"/><line x1="12" y1="1" x2="12" y2="3"/><line x1="12" y1="21" x2="12" y2="23"/><line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/><line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/><line x1="1" y1="12" x2="3" y2="12"/><line x1="21" y1="12" x2="23" y2="12"/><line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/><line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/></svg>
        </button>
        <a href="/consulting/" class="nav-cta">Consulting</a>
      </div>
    </nav>
  </header>

  <div class="nav-overlay" id="navOverlay" role="dialog" aria-label="Navigation menu">
    <div class="overlay-inner">
      <div>
        <div class="overlay-topics-label">Topics</div>
        <ul class="overlay-topics">
          <li><a href="/voussoir-archive/?topic=ai-regulation">AI &amp; Regulation</a></li>
          <li><a href="/voussoir-archive/?topic=digital-governance">Digital Governance</a></li>
          <li><a href="/voussoir-archive/?topic=data-privacy">Data &amp; Privacy</a></li>
          <li><a href="/voussoir-archive/?topic=govtech">GovTech</a></li>
          <li><a href="/voussoir-archive/?topic=public-administration">Public Administration</a></li>
          <li><a href="/voussoir-archive/?topic=eu-policy">EU Policy</a></li>
