  <main>
    {{ content | safe }}
  </main>

  <footer class="footer">
    <span class="footer-logo">v<span>.</span></span>
    <span class="footer-copy">© {{ page.date.getFullYear() }} Voussoir. Tutti i diritti riservati.</span>
    <div class="footer-links">
      <a href="/analisi/">Analisi</a>
      <a href="/consulenza/">Consulenza</a>
