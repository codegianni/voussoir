<!DOCTYPE html>
<html lang="en-GB" data-theme="">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta name="robots" content="noindex, nofollow">
  <title>{{ title }} | Voussoir</title>
  <meta name="description" content="{{ deck }}">
  <meta property="og:title" content="{{ title }} | Voussoir">
  <meta property="og:description" content="{{ deck }}">
  <meta property="og:type" content="article">
  <meta property="og:url" content="https://voussoir.eu{{ page.url }}">
  <meta name="twitter:card" content="summary_large_image">
  <meta name="twitter:title" content="{{ title }} | Voussoir">
  <link rel="icon" type="image/svg+xml" href="/img/favicon.svg?v=2">
  <link rel="alternate icon" type="image/png" href="/img/favicon.png?v=2">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=DM+Serif+Display:ital@0;1&family=Playfair+Display:ital,wght@0,400;0,600;0,700;1,400&family=Inter:wght@300;400;500;600&display=swap" rel="stylesheet">
  <style>
    /* RESET */
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    /* LIGHT TOKENS */
    :root {
      --ink:          #111111;
      --ink-soft:     #484848;
      --ink-faint:    #888888;
      --paper:        #ffffff;
      --cream:        #f2f2f2;
      --rule:         #d8d8d8;
      --surface-dark: #111111;
      --serif:   'Playfair Display', Georgia, serif;
      --display: 'DM Serif Display', Georgia, serif;
      --sans:    'Inter', system-ui, sans-serif;
    }

    @media (prefers-color-scheme: dark) {
      :root:not([data-theme="light"]) {
        --ink:          #e8e8e8;
        --ink-soft:     #969696;
        --ink-faint:    #585858;
        --paper:        #111111;
        --cream:        #1a1a1a;
        --rule:         #2a2a2a;
        --surface-dark: #080808;
      }
    }

    [data-theme="light"] {
      --ink:          #111111;
      --ink-soft:     #484848;
      --ink-faint:    #888888;
      --paper:        #ffffff;
      --cream:        #f2f2f2;
      --rule:         #d8d8d8;
      --surface-dark: #111111;
    }

    [data-theme="dark"] {
      --ink:          #e8e8e8;
      --ink-soft:     #969696;
      --ink-faint:    #585858;
      --paper:        #111111;
      --cream:        #1a1a1a;
      --rule:         #2a2a2a;
      --surface-dark: #080808;
    }

    html { scroll-behavior: smooth; }

    body {
      font-family: var(--sans);
      background: var(--paper);
      color: var(--ink);
      font-size: 16px;
      line-height: 1.6;
      -webkit-font-smoothing: antialiased;
    }

    a { color: inherit; text-decoration: none; }


    /* ARTICLE HERO */
    .article-hero {
      border-bottom: 1px solid var(--rule);
      padding: 64px 0 0;
    }
    .article-hero-inner {
      max-width: 760px;
      margin: 0 auto;
      padding: 0 32px;
    }

    .article-breadcrumb {
      font-size: 11px;
      font-weight: 600;
      text-transform: uppercase;
      letter-spacing: 0.1em;
      color: var(--ink-faint);
      margin-bottom: 24px;
    }
    .article-breadcrumb a { color: inherit; }
    .article-breadcrumb a:hover { color: var(--ink); }

    .article-badges {
      display: flex;
      gap: 8px;
      margin-bottom: 28px;
      align-items: center;
      flex-wrap: wrap;
    }
    .badge {
      font-size: 11px;
      font-weight: 600;
      text-transform: uppercase;
      letter-spacing: 0.06em;
      padding: 5px 10px;
      border-radius: 2px;
    }
    .badge--filled {
      background: var(--ink);
      color: var(--paper);
    }
    .badge--outline {
      border: 1px solid var(--rule);
      color: var(--ink-soft);
    }

    .article-title {
      font-family: var(--display);
      font-size: 52px;
      font-weight: 400;
      line-height: 1.08;
      color: var(--ink);
      margin-bottom: 24px;
      letter-spacing: -0.02em;
    }

    .article-deck {
      font-family: var(--serif);
      font-size: 20px;
      font-weight: 400;
      line-height: 1.55;
      color: var(--ink-soft);
      margin-bottom: 32px;
    }

    .article-meta {
      display: flex;
      align-items: center;
      gap: 20px;
      font-size: 13px;
      color: var(--ink-faint);
      padding-bottom: 32px;
      border-bottom: 1px solid var(--rule);
      margin-bottom: 32px;
      flex-wrap: wrap;
    }
    .article-meta-author {
      font-weight: 500;
      color: var(--ink);
    }
    .article-meta-sep { color: var(--rule); }

    .article-ctas {
      display: flex;
      gap: 12px;
      padding-bottom: 40px;
      flex-wrap: wrap;
    }
    .btn {
      padding: 11px 24px;
      font-size: 12px;
      font-weight: 600;
      text-transform: uppercase;
      letter-spacing: 0.06em;
      border: none;
      cursor: pointer;
      border-radius: 2px;
      text-decoration: none;
      display: inline-block;
      transition: opacity 0.2s;
    }
    .btn--filled {
      background: var(--ink);
      color: var(--paper);
    }
    .btn--filled:hover { opacity: 0.8; }
    .btn--outline {
      border: 1px solid var(--rule);
      background: transparent;
      color: var(--ink);
    }
    .btn--outline:hover { border-color: var(--ink); }

    /* Hero image */
    .hero-image-wrap {
      width: 100%;
      max-width: 1200px;
      margin: 0 auto;
      aspect-ratio: 21 / 8;
      background: var(--cream);
      display: flex;
      align-items: center;
      justify-content: center;
      overflow: hidden;
    }
    .hero-image-placeholder {
      font-size: 12px;
      color: var(--ink-faint);
      text-transform: uppercase;
      letter-spacing: 0.1em;
    }

    /* ARTICLE BODY */
    .article-body {
      max-width: 760px;
      margin: 0 auto;
      padding: 64px 32px 96px;
    }

    .article-body p {
      font-size: 17px;
      line-height: 1.85;
      color: var(--ink-soft);
      margin-bottom: 28px;
      overflow-wrap: break-word;
      word-break: break-word;
    }

    .article-body h2 {
      font-family: var(--serif);
      font-size: 26px;
      font-weight: 600;
      color: var(--ink);
      margin-top: 56px;
      margin-bottom: 24px;
      padding-top: 24px;
      border-top: 1px solid var(--rule);
    }

    /* Pull quote */
    .pull-quote {
      font-family: var(--display);
      font-size: 24px;
      font-style: italic;
      color: var(--ink);
      line-height: 1.5;
      border-left: 3px solid var(--ink);
      padding-left: 24px;
      margin: 48px 0;
    }

    /* MORE REPORTS */
    .more-reports {
      background: var(--cream);
      padding: 64px 0;
      border-top: 1px solid var(--rule);
    }
    .more-reports-inner {
      max-width: 1200px;
      margin: 0 auto;
      padding: 0 32px;
    }
    .more-reports-inner h2 {
      font-family: var(--serif);
      font-size: 28px;
      font-weight: 400;
      color: var(--ink);
      margin-bottom: 40px;
    }
    .reports-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 40px;
    }
    .report-card-num {
      font-family: var(--display);
      font-size: 44px;
      color: var(--ink-faint);
      line-height: 1;
      margin-bottom: 14px;
    }
    .report-card-meta {
      font-size: 11px;
      color: var(--ink-faint);
      text-transform: uppercase;
      letter-spacing: 0.06em;
      margin-bottom: 6px;
    }
    .report-card-date {
      font-size: 11px;
      color: var(--ink-faint);
      margin-bottom: 10px;
    }
    .report-card-title {
      font-family: var(--serif);
      font-size: 19px;
      font-weight: 400;
      color: var(--ink);
      line-height: 1.3;
      margin-bottom: 8px;
    }
    .report-card-pages {
      font-size: 12px;
      color: var(--ink-soft);
    }

    /* UNIFIED COMPACT FOOTER */
    .site-footer {
      background: var(--paper);
      border-top: 1px solid var(--rule);
      padding: 40px 0 36px;
    }
    .footer-inner {
      max-width: 1200px;
      margin: 0 auto;
      padding: 0 32px;
      display: grid;
      grid-template-columns: 2fr 1fr 1fr 1fr;
      gap: 32px;
    }
    .footer-brand-name {
      font-family: var(--serif);
      font-size: 36px;
      font-weight: 700;
      letter-spacing: -0.5px;
      color: var(--ink);
      text-decoration: none;
      display: block;
      margin-bottom: 10px;
    }
    .footer-brand-desc {
      font-size: 12px;
      color: var(--ink-faint);
      line-height: 1.5;
      margin-bottom: 16px;
    }
    .footer-copy {
      font-size: 11px;
      color: var(--ink-faint);
    }
    .footer-copy a { color: inherit; }
    .footer-col-head {
      font-size: 10px;
      font-weight: 600;
      text-transform: uppercase;
      letter-spacing: 0.08em;
      color: var(--ink-faint);
      margin-bottom: 12px;
    }
    .footer-col-list { list-style: none; }
    .footer-col-list li { margin-bottom: 8px; }
    .footer-col-list a {
      font-size: 13px;
      color: var(--ink-soft);
      text-decoration: none;
      transition: color 0.15s;
    }
    .footer-col-list a:hover { color: var(--ink); }

    /* RESPONSIVE */
    @media (max-width: 900px) {
      .article-title { font-size: 40px; }
      .reports-grid { grid-template-columns: 1fr 1fr; }
      .footer-inner { grid-template-columns: 1fr 1fr; }
    }
    @media (max-width: 640px) {
      .article-hero-inner { padding: 0 20px; }
      .article-body { padding: 48px 20px 72px; }
      .article-title { font-size: 32px; }
      .article-deck { font-size: 17px; }
      .reports-grid { grid-template-columns: 1fr; }
      .footer-inner { grid-template-columns: 1fr; padding: 0 20px; }
    }

    @media (max-width: 480px) {
      .article-title { font-size: 28px; }
      .article-deck { font-size: 16px; }
      .footer-inner { grid-template-columns: 1fr; padding: 0 16px; }
      .reports-grid { grid-template-columns: 1fr; }
      .overlay-inner { padding: 0 16px; gap: 32px; }
    }

    /* SITE HEADER & NAV */
    .site-header {
      position: sticky; top: 0; z-index: 200;
      background: var(--paper); border-bottom: 1px solid var(--rule);
      transition: background 0.3s, border-color 0.3s;
    }
    .nav-inner {
      display: grid; grid-template-columns: 1fr auto 1fr;
      align-items: center; height: 64px; padding: 0 24px;
    }
    .nav-left { display: flex; align-items: center; gap: 20px; }
    .site-logo {
      font-family: var(--serif); font-size: 26px; font-weight: 700;
      letter-spacing: -0.5px; color: var(--ink); line-height: 1;
      grid-column: 2; justify-self: center; white-space: nowrap; text-decoration: none;
    }
    .nav-right { display: flex; align-items: center; gap: 16px; justify-content: flex-end; }
    .nav-icon-btn {
      background: none; border: none; cursor: pointer; color: var(--ink);
      display: flex; align-items: center; justify-content: center;
      padding: 4px; transition: opacity 0.2s;
    }
    .nav-icon-btn:hover { opacity: 0.5; }
    .nav-icon-btn svg { width: 20px; height: 20px; stroke: currentColor; fill: none; stroke-width: 1.5; stroke-linecap: round; stroke-linejoin: round; }
    .icon-close { display: none; } .icon-burger { display: block; }
    .menu-open .icon-close { display: block; } .menu-open .icon-burger { display: none; }
    .icon-sun { display: none; } .icon-moon { display: block; }
    [data-theme="dark"] .icon-sun { display: block; } [data-theme="dark"] .icon-moon { display: none; }
    @media (prefers-color-scheme: dark) {
      html:not([data-theme="light"]) .icon-sun { display: block; }
      html:not([data-theme="light"]) .icon-moon { display: none; }
    }
    .nav-cta {
      font-family: var(--sans); font-size: 11px; font-weight: 500;
      letter-spacing: 0.1em; text-transform: uppercase; color: var(--ink);
      border: 1px solid var(--ink); padding: 7px 16px; border-radius: 999px;
      white-space: nowrap; transition: background 0.2s, color 0.2s; text-decoration: none;
    }
    .nav-cta:hover { background: var(--ink); color: var(--paper); }
    .nav-overlay {
      position: fixed; top: 64px; left: 0; right: 0; background: var(--paper);
      border-top: 1px solid var(--rule); border-bottom: 1px solid var(--rule);
      z-index: 199; padding: 52px 0 60px;
      opacity: 0; pointer-events: none; transform: translateY(-8px);
      transition: opacity 0.25s ease, transform 0.25s ease;
    }
    .nav-overlay.is-open { opacity: 1; pointer-events: all; transform: translateY(0); }
    .overlay-inner {
      max-width: 1200px; margin: 0 auto; padding: 0 32px;
      display: grid; grid-template-columns: 3fr 2fr; gap: 80px; align-items: start;
    }
    .overlay-topics-label, .overlay-search-label {
      font-family: var(--sans); font-size: 10px; font-weight: 700;
      letter-spacing: 0.2em; text-transform: uppercase;
      color: var(--ink-faint); margin-bottom: 28px;
    }
    .overlay-topics { list-style: none; display: grid; grid-template-columns: 1fr 1fr; }
    .overlay-topics li a {
      font-family: var(--serif); font-size: 26px; font-weight: 400; color: var(--ink);
      line-height: 1.25; display: block; padding: 10px 0;
      transition: opacity 0.2s; text-decoration: none;
    }
    .overlay-topics li a:hover { opacity: 0.4; }
    .overlay-topics li:nth-child(odd) a { padding-right: 32px; }
    .overlay-topics li:nth-child(even) a { padding-left: 32px; }
    .overlay-topics li:last-child:nth-child(odd) { grid-column: 1 / -1; }
    .overlay-topics li:last-child:nth-child(odd) a { padding-right: 0; border-left: none; }
    .overlay-search-form {
      display: flex; align-items: center;
      border-bottom: 1px solid var(--ink); padding-bottom: 2px; gap: 8px;
    }
    .overlay-search-input {
      font-family: var(--serif); font-size: 20px; background: none;
      border: none; outline: none; color: var(--ink); flex: 1; padding: 10px 0;
      font-style: italic;
    }
    .overlay-search-input::placeholder { color: var(--ink-faint); font-style: italic; }
    .overlay-search-btn {
      background: none; border: none; cursor: pointer;
      font-family: var(--sans); font-size: 12px; font-weight: 600;
      letter-spacing: 0.12em; text-transform: uppercase;
      color: var(--ink-faint); padding: 10px 0; transition: color 0.2s; white-space: nowrap;
    }
    .overlay-search-btn:hover { color: var(--ink); }
  </style>
</head>
<body>

  <!-- HEADER -->
  <header class="site-header" id="siteHeader">
    <nav class="nav-inner">
      <div class="nav-left">
        <button class="nav-icon-btn" id="menuToggle" aria-label="Open menu" aria-expanded="false">
          <svg class="icon-burger" viewBox="0 0 24 24"><line x1="3" y1="6" x2="21" y2="6"/><line x1="3" y1="12" x2="21" y2="12"/><line x1="3" y1="18" x2="21" y2="18"/></svg>
          <svg class="icon-close" viewBox="0 0 24 24"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
        </button>
        <button class="nav-icon-btn" id="searchToggle" aria-label="Search">
          <svg viewBox="0 0 24 24"><circle cx="11" cy="11" r="7"/><line x1="16.5" y1="16.5" x2="22" y2="22"/></svg>
        </button>
      </div>
      <a href="/" class="site-logo">Voussoir.</a>
      <div class="nav-right">
        <button class="nav-icon-btn" id="themeToggle" aria-label="Toggle dark mode">
          <svg class="icon-moon" viewBox="0 0 24 24"><path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/></svg>
          <svg class="icon-sun" viewBox="0 0 24 24"><circle cx="12" cy="12" r="5"/><line x1="12" y1="1" x2="12" y2="3"/><line x1="12" y1="21" x2="12" y2="23"/><line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/><line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/><line x1="1" y1="12" x2="3" y2="12"/><line x1="21" y1="12" x2="23" y2="12"/><line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/><line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/></svg>
        </button>
        <a href="/consulting/" class="nav-cta">Consulting</a>
      </div>
    </nav>
  </header>

  <div class="nav-overlay" id="navOverlay" role="dialog" aria-label="Navigation menu">
    <div class="overlay-inner">
      <div>
        <div class="overlay-topics-label">Topics</div>
        <ul class="overlay-topics">
          <li><a href="/voussoir-archive/?topic=ai-regulation">AI &amp; Regulation</a></li>
          <li><a href="/voussoir-archive/?topic=digital-governance">Digital Governance</a></li>
          <li><a href="/voussoir-archive/?topic=data-privacy">Data &amp; Privacy</a></li>
          <li><a href="/voussoir-archive/?topic=govtech">GovTech</a></li>
          <li><a href="/voussoir-archive/?topic=public-administration">Public Administration</a></li>
          <li><a href="/voussoir-archive/?topic=eu-policy">EU Policy</a></li>
          <li><a href="/voussoir-archive/?topic=comparative-policy">Comparative Policy</a></li>
        </ul>
      </div>
      <div>
        <div class="overlay-search-label">Search</div>
        <form class="overlay-search-form" onsubmit="return false;">
          <input class="overlay-search-input" type="search" placeholder="Search articles and reports…"/>
          <button class="overlay-search-btn" aria-label="Go" type="submit">Go</button>
        </form>
      </div>
    </div>
  </div>


  <!-- ARTICLE HERO -->
  <section class="article-hero">
    <div class="article-hero-inner">
      <p class="article-breadcrumb"><a href="/voussoir-archive/">Policy Reports</a> → <a href="/voussoir-archive/?topic={{ topic }}">{{ topicLabel }}</a></p>

      <div class="article-badges">
        <span class="badge badge--filled">Policy Report</span>
        <span class="badge badge--outline">No. {{ reportNumber }} / {{ reportYear }}</span>
        <span class="badge badge--outline">{{ additionalTopic }}</span>
      </div>

      <h1 class="article-title">{{ title }}</h1>

      <p class="article-deck">{{ deck }}</p>

      <div class="article-meta">
        <span class="article-meta-author">Giovanni Perrini</span>
        <span class="article-meta-sep">·</span>
        <span>{{ date | readableDate }}</span>
        <span class="article-meta-sep">·</span>
        <span>{{ pages }} pages</span>
      </div>

      <div class="article-ctas">
        <a href="#" class="btn btn--filled">Download full report (PDF)</a>
        <a href="#" class="btn btn--outline">Executive summary</a>
      </div>
    </div>
  </section>

  <!-- Hero image -->
  <div class="hero-image-wrap">
    <span class="hero-image-placeholder">Hero image</span>
  </div>

  <!-- ARTICLE BODY -->
  <article class="article-body">
    {{ content | safe }}
  </article>

  <!-- MORE REPORTS -->
  <section class="more-reports">
    <div class="more-reports-inner">
      <h2>More reports</h2>
      <div class="reports-grid">
        {% set relatedReports = collections.reports | rejectattr("url", "equalto", page.url) | slice(0, 3) %}
        {% for post in relatedReports %}
        <div>
          <div class="report-card-num">{{ post.data.reportNumber }}</div>
          <p class="report-card-meta">{{ post.data.topic }}</p>
          <p class="report-card-date">{{ post.date | readableDate }}</p>
          <p class="report-card-title">{{ post.data.title }}</p>
          <p class="report-card-pages">{{ post.data.pages }} pages</p>
        </div>
        {% endfor %}
      </div>
    </div>
  </section>

  <!-- FOOTER -->
  <footer class="site-footer">
    <div class="footer-inner">
      <div>
        <a href="/" class="footer-brand-name">Voussoir.</a>
        <p class="footer-brand-desc">Independent policy analysis and strategic consulting by Giovanni Perrini.</p>
        <p class="footer-copy">© 2026 Giovanni Perrini · <a href="#">Privacy</a> · <a href="#">Terms</a></p>
      </div>
      <div>
        <p class="footer-col-head">Topics</p>
        <ul class="footer-col-list">
          <li><a href="/voussoir-archive/?topic=ai-regulation">AI &amp; Regulation</a></li>
          <li><a href="/voussoir-archive/?topic=digital-governance">Digital Governance</a></li>
          <li><a href="/voussoir-archive/?topic=data-privacy">Data &amp; Privacy</a></li>
          <li><a href="/voussoir-archive/?topic=govtech">GovTech</a></li>
          <li><a href="/voussoir-archive/?topic=public-administration">Public Administration</a></li>
          <li><a href="/voussoir-archive/?topic=eu-policy">EU Policy</a></li>
          <li><a href="/voussoir-archive/?topic=comparative-policy">Comparative Policy</a></li>
        </ul>
      </div>
      <div>
        <p class="footer-col-head">About</p>
        <ul class="footer-col-list">
          <li><a href="#">About</a></li>
          <li><a href="#">Consulting</a></li>
          <li><a href="#">Publications</a></li>
          <li><a href="#">Contact</a></li>
        </ul>
      </div>
      <div>
        <p class="footer-col-head">Follow</p>
        <ul class="footer-col-list">
          <li><a href="#">Newsletter</a></li>
          <li><a href="#">LinkedIn</a></li>
          <li><a href="#">𝕏 / Twitter</a></li>
          <li><a href="#">Bluesky</a></li>
          <li><a href="#">RSS Feed</a></li>
        </ul>
      </div>
    </div>
  </footer>

  <script>
    (function () {
      const html = document.documentElement;
      const themeBtn = document.getElementById('themeToggle');
      const menuBtn = document.getElementById('menuToggle');
      const searchBtn = document.getElementById('searchToggle');
      const overlay = document.getElementById('navOverlay');
      const header = document.getElementById('siteHeader');
      const searchInput = overlay.querySelector('.overlay-search-input');
      const KEY = 'voussoir-theme';
      const saved = localStorage.getItem(KEY);
      if (saved === 'dark' || saved === 'light') html.setAttribute('data-theme', saved);
      function isDark() {
        const t = html.getAttribute('data-theme');
        if (t === 'dark') return true;
        if (t === 'light') return false;
        return window.matchMedia('(prefers-color-scheme: dark)').matches;
      }
      themeBtn.addEventListener('click', function () {
        const next = isDark() ? 'light' : 'dark';
        html.setAttribute('data-theme', next);
        localStorage.setItem(KEY, next);
      });
      window.matchMedia('(prefers-color-scheme: dark)').addEventListener('change', function () {
        if (!localStorage.getItem(KEY)) html.setAttribute('data-theme', '');
      });
      let menuOpen = false;
      function openMenu() {
        menuOpen = true; overlay.classList.add('is-open');
        header.classList.add('menu-open');
        menuBtn.setAttribute('aria-expanded', 'true');
        menuBtn.setAttribute('aria-label', 'Close menu');
      }
      function closeMenu() {
        menuOpen = false; overlay.classList.remove('is-open');
        header.classList.remove('menu-open');
        menuBtn.setAttribute('aria-expanded', 'false');
        menuBtn.setAttribute('aria-label', 'Open menu');
      }
      menuBtn.addEventListener('click', function () { menuOpen ? closeMenu() : openMenu(); });
      searchBtn.addEventListener('click', function () {
        if (!menuOpen) openMenu();
        setTimeout(function () { searchInput.focus(); }, 50);
      });
      overlay.querySelectorAll('a').forEach(function (link) { link.addEventListener('click', closeMenu); });
      document.addEventListener('keydown', function (e) { if (e.key === 'Escape' && menuOpen) closeMenu(); });
    })();
  </script>

  {% include "partials/cookie-banner.njk" %}
</body>
</html>
