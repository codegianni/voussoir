---
layout: layouts/base.njk
title: Voussoir
description: Rivista indipendente di analisi delle politiche pubbliche. Rigore accademico, prospettiva europea, vocazione professionale.
---

<!-- HERO -->
<section class="hero">
  <div class="hero-left">
    <div>
      <div class="hero-tag">Politiche pubbliche · Analisi indipendente</div>
      <h1 class="hero-title">
        Costruire archi<br>
        che <em>reggono</em><br>
        nel tempo.
      </h1>
      <p class="hero-desc">
        Voussoir è una rivista indipendente di analisi delle politiche pubbliche.
        Rigore accademico, prospettiva europea, vocazione professionale.
      </p>
      <a href="/analisi/" class="hero-btn">Leggi le analisi →</a>
    </div>
  </div>

  <div class="hero-right">
    <svg class="arch-decoration" viewBox="0 0 400 420" fill="none" xmlns="http://www.w3.org/2000/svg" style="position:absolute;top:0;left:0;width:100%;height:100%">
      <path d="M200 370 L70 370 L70 195 Q70 105 200 105 Q330 105 330 195 L330 370 Z" stroke="#1C1A16" stroke-width="2" fill="none"/>
      <path d="M200 350 L95 350 L95 200 Q95 130 200 130 Q305 130 305 200 L305 350 Z" stroke="#1C1A16" stroke-width="1" fill="none"/>
      <path d="M200 330 L118 330 L118 205 Q118 155 200 155 Q282 155 282 205 L282 330 Z" stroke="#1C1A16" stroke-width="0.5" fill="none"/>
      <line x1="50" y1="370" x2="350" y2="370" stroke="#1C1A16" stroke-width="1.5"/>
      <circle cx="200" cy="105" r="4" fill="#1C1A16"/>
      <path d="M200 105 L200 60" stroke="#1C1A16" stroke-width="0.5" stroke-dasharray="3 3"/>
      <text x="200" y="52" text-anchor="middle" font-family="Outfit,sans-serif" font-size="9" letter-spacing="3" fill="#1C1A16">CHIAVE DI VOLTA</text>
    </svg>

    {% set primo = collections.articoli | first %}
    {% if primo %}
    <div class="hero-featured-label">In primo piano</div>
    <a href="{{ primo.url }}">
      <div class="hero-featured-title">{{ primo.data.title }}</div>
    </a>
    <div class="hero-featured-sub">{{ primo.data.sottotitolo }}</div>
    <div class="hero-featured-meta">{{ primo.data.autore }} · {{ primo.data.tema }} · {{ primo.content | tempoLettura }}</div>
    {% endif %}
  </div>
</section>

<!-- STRISCIA NUMERI -->
<div class="number-strip">
  <div class="number-cell">
    <div class="number-value">{{ collections.articoli | length }}</div>
    <div class="number-label">Analisi pubblicate</div>
  </div>
  <div class="number-cell">
    <div class="number-value">4</div>
    <div class="number-label">Aree tematiche</div>
  </div>
  <div class="number-cell">
    <div class="number-value">EU</div>
    <div class="number-label">Prospettiva europea</div>
  </div>
  <div class="number-cell">
    <div class="number-value">OA</div>
    <div class="number-label">Open access</div>
  </div>
</div>

<!-- ULTIMI ARTICOLI -->
<div class="section-bar">
  <span class="section-title">Ultime analisi</span>
  <a href="/analisi/" class="section-all">Vedi tutte →</a>
</div>

<div class="articles-grid">
  {% for articolo in collections.articoli | slice(0, 3) %}
  <a href="{{ articolo.url }}" class="article-card">
    <div class="article-topic">{{ articolo.data.tema }}</div>
    <div class="article-title">{{ articolo.data.title }}</div>
    <div class="article-excerpt">{{ articolo.data.sottotitolo }}</div>
    <div class="article-meta">
      <span>{{ articolo.data.autore }}</span>
      <span class="meta-dot"></span>
      <span>{{ articolo.content | tempoLettura }}</span>
      <span class="meta-dot"></span>
      <span>{{ articolo.page.date | dataItaliana }}</span>
    </div>
  </a>
  {% endfor %}
</div>

<!-- PANNELLO INFERIORE -->
<div class="bottom-strip">
  <div class="consulting-panel">
    <div class="consulting-label">Consulenza</div>
    <div class="consulting-title">Europrogettazione<br>e <em>public policy</em></div>
    <div class="consulting-desc">
      Supporto professionale per enti pubblici, organizzazioni e imprese
      nella progettazione di politiche e nell'accesso ai fondi europei.
    </div>
    <a href="/consulenza/" class="consulting-btn">Scopri i servizi →</a>
  </div>

  <div class="about-panel">
    <div class="about-label">Il fondatore</div>
    <div class="about-name">Giovanni Perrini</div>
    <div class="about-role">Policy analyst · MA Economics & Communication, USI Lugano</div>
    <div class="about-bio">
      Ricercatore e analista di politiche pubbliche con esperienza in governance europea,
      finanza pubblica e comunicazione istituzionale. Laureato magna cum laude a Lugano,
      già visiting a Berna e Atene.
    </div>
    <div class="tags">
      <span class="tag">EU Policy</span>
      <span class="tag">PNRR</span>
      <span class="tag">Governance</span>
      <span class="tag">Europrogettazione</span>
    </div>
  </div>
</div>
